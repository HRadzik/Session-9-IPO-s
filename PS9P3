def compute_price(msrp, make, model, ev_code):
    make = make.lower()
    model = model.lower()
    ev_code = ev_code.lower()
    if make == "honda" and model == "accord":
        discount = 0.10
    elif make == "toyota" and model == "rav4":
        discount = 0.15
    elif ev_code == "y":
        discount = 0.30
    else:
        discount = 0.05
    discounted_price = msrp - (msrp * discount)
    final_price = discounted_price * 1.07
    return final_price
total_msrp = 0
total_sales = 0
choice = "yes"
while choice.lower() == "yes":
    make = input("Enter make: ")
    model = input("Enter model: ")
    ev = input("Electric vehicle (Y/N): ")
    msrp = float(input("Enter MSRP: "))
    final_price = compute_price(msrp, make, model, ev)
    total_msrp += msrp
    total_sales += final_price
    print("Out-the-door price:", round(final_price, 2))
    choice = input("Do you want to continue? (Yes/No): ")
print("Total MSRP:", round(total_msrp, 2))
print("Total Sales Price:", round(total_sales, 2))
